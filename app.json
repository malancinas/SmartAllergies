{
  "expo": {
    "name": "Local Allergies",
    "slug": "local-allergies",
    "scheme": "localallergies",
    "platforms": [
      "ios",
      "android"
    ],
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/splash/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.malancinas.localallergies",
      "supportsTablet": true
    },
    "android": {
      "package": "com.malancinas.localallergies",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      "expo-sqlite",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Local Allergies uses your location to fetch local pollen and weather data."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#ffffff"
        }
      ],
      [
        "react-native-maps",
        {
          "googleMapsApiKey": "YOUR_ANDROID_MAPS_KEY"
        }
      ],
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.356012542328-bhc46uh02rl7tpmf0m2qhm24g8rhoe3v"
        }
      ]
    ]
  }
}
